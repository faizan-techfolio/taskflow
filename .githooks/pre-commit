#!/bin/sh
echo "Running pre-commit syntax check..."

docker run --rm \
  -v "$(pwd)":/app \
  -w /app \
  node:20-alpine \
  node --check backend/server.js

if [ $? -ne 0 ]; then
  echo "❌ Syntax error in backend/server.js — commit blocked!"
  exit 1
fi

echo "✅ Syntax check passed — committing."
exit 0
